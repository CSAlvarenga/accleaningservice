# Google Places API (New) — used by: npm run fetch-reviews
# Get a key at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (New)
GOOGLE_PLACES_API_KEY=your_api_key_here

# Place ID for AClean Building Solutions (ChIJ... format from Places API New).
# Leave blank to auto-discover via text search (uses one extra API call).
GOOGLE_PLACE_ID=
